VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre-clé-anon-publique

# Optionnel — mode « foyer unique verrouillé » (déploiement mono-famille).
# Si défini, l'appli reste dédiée à ce seul foyer (comportement historique).
# Laissez vide pour le mode PRODUIT multi-foyer (chacun crée/rejoint son Nid).
# VITE_NID_CODE=notre-maison

# Optionnel — vraies notifications push (Phase 2). Clé PUBLIQUE VAPID.
# Générer la paire avec :  npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY=votre-clé-publique-vapid
